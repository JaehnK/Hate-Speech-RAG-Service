#!/bin/sh
set -eu

export NGINX_RESOLVER="${NGINX_RESOLVER:-$(awk '/^nameserver[[:space:]]+/ { print $2; exit }' /etc/resolv.conf)}"
export NGINX_RESOLVER="${NGINX_RESOLVER:-127.0.0.11}"

case "$NGINX_RESOLVER" in
    *:*)
        case "$NGINX_RESOLVER" in
            \[*\]) ;;
            *) export NGINX_RESOLVER="[$NGINX_RESOLVER]" ;;
        esac
        ;;
esac
