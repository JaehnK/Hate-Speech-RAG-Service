APP_ENV=development
LOG_LEVEL=INFO
POSTGRES_PASSWORD=hatespeech
DATABASE_URL=postgresql+psycopg://hatespeech:hatespeech@localhost:5432/hatespeech
ADMIN_TOKEN=change-me
REPORT_STORAGE_DIR=data/reports
YOUTUBE_API_KEY=
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_STALE_AFTER_SECONDS=900
RAG_EXECUTION_MODE=sequential
RAG_ITEM_CONCURRENCY=2
RAG_EMBEDDING_CONCURRENCY=2
RAG_LLM_CONCURRENCY=2
RAG_ITEM_MAX_ATTEMPTS=3
RAG_HEARTBEAT_INTERVAL_SECONDS=30
RAG_SHUTDOWN_GRACE_SECONDS=30
RAG_REQUEST_TIMEOUT_SECONDS=30
PIPELINE_MODE=fake

CHROMA_PERSIST_DIRECTORY=.chroma

EMBEDDING_PROVIDER=upstage
EMBEDDING_MODEL=solar-embedding-1-large
